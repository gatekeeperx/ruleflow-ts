{
  "name": "ts-ruleflow",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run -w @ruleflow/dsl-core build",
    "typecheck": "npm run -w @ruleflow/dsl-core typecheck",
    "clean": "npm run -w @ruleflow/dsl-core clean",
    "test": "npm run -w @ruleflow/dsl-tests test",
    "dev:next": "npm run -w @ruleflow/next-demo dev",
    "build:next": "npm run -w @ruleflow/next-demo build",
    "start:next": "npm run -w @ruleflow/next-demo start",
    "dev:all": "concurrently -n core,next -c green,cyan \"npm run -w @ruleflow/dsl-core watch\" \"npm run -w @ruleflow/next-demo dev\""
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
