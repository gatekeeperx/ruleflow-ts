{
  "name": "@ruleflow/dsl-tests",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "commonjs",
  "description": "Golden tests for @ruleflow/dsl-core using Vitest",
  "scripts": {
    "pretest": "npm run -w @ruleflow/dsl-core build",
    "pretest:coverage": "npm run -w @ruleflow/dsl-core build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --reporter=default",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ruleflow/dsl-core": "file:../dsl-core"
  },
  "devDependencies": {
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0"
  }
}