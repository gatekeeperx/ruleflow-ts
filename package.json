{
  "name": "ts-ruleflow",
  "description": "Monorepo for Ruleflow DSL: core interpreter, tests, and Next.js demo.",
  "license": "MIT",
  "private": true,
  "author": "Rodolfo Rivas",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gatekeeperx/ruleflow-ts.git"
  },
  "bugs": {
    "url": "https://github.com/gatekeeperx/ruleflow-ts/issues"
  },
  "homepage": "https://github.com/gatekeeperx/ruleflow-ts#readme",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run -w @ruleflow/dsl-core build",
    "typecheck": "npm run -w @ruleflow/dsl-core typecheck",
    "clean": "npm run -w @ruleflow/dsl-core clean",
    "test": "npm run test:coverage",
    "test:coverage": "npm run -w @ruleflow/dsl-tests test:coverage",
    "smoke": "npm run -w @ruleflow/dsl-core smoke",
    "dev:next": "npm run -w @ruleflow/next-demo dev",
    "build:next": "npm run -w @ruleflow/next-demo build",
    "start:next": "npm run -w @ruleflow/next-demo start",
    "dev:all": "concurrently -n core,next -c green,cyan \"npm run -w @ruleflow/dsl-core watch\" \"npm run -w @ruleflow/next-demo dev\""
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}